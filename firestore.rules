rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net (First matching rule blocks everything by default)
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definitions
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedUser() {
      return isSignedIn() && (
        request.auth.token.get('email_verified', false) == true ||
        request.auth.token.firebase.sign_in_provider == 'google.com' ||
        request.auth.token.firebase.sign_in_provider == 'anonymous' ||
        request.auth.token.firebase.sign_in_provider == 'phone'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // === Clinic staff (web console) ===
    // Staff sign in with dedicated email/password accounts. Access requires a
    // password changed within the last 30 days (rotation is enforced here, not
    // just in the UI): staffMeta/{uid}.passwordChangedAt must be fresh.
    function isStaffEmail() {
      return isSignedIn() && (
        request.auth.token.email == 'doctor@geetaendocrine.com' ||
        request.auth.token.email == 'staff@geetaendocrine.com'
      );
    }

    function staffPasswordFresh() {
      return get(/databases/$(database)/documents/staffMeta/$(request.auth.uid))
        .data.passwordChangedAt > request.time - duration.value(30, 'd');
    }

    function isActiveStaff() {
      return isStaffEmail() && staffPasswordFresh();
    }

    function isDoctor() {
      return isSignedIn() && request.auth.token.email == 'doctor@geetaendocrine.com';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Standalone Validation Helpers (The Anti-Update-Gaps)
    function isValidUser(data) {
      return data.keys().hasAll(['name', 'email', 'createdAt'])
        && data.keys().size() >= 3
        && data.keys().size() <= 5
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 100
        && data.email is string
        && data.email.size() > 0
        && data.email.size() <= 100
        && data.createdAt is timestamp
        && (
          !('phone' in data) || (
            data.phone is string && data.phone.size() <= 30
          )
        )
        && (
          !('address' in data) || (
            data.address is string && data.address.size() <= 200
          )
        );
    }

    function isValidGlucose(data) {
      return data.keys().hasAll(['timestamp', 'type', 'value'])
        && data.keys().size() >= 3
        && data.keys().size() <= 4
        && data.timestamp is string
        && data.timestamp.size() > 0
        && data.timestamp.size() <= 50
        && data.type is string
        && (data.type == 'Fasting' || data.type == 'Post-Prandial' || data.type == 'Random')
        && (data.value is int || data.value is float)
        && data.value >= 10
        && data.value <= 1000
        && (
          !('notes' in data) || (
            data.notes is string && data.notes.size() <= 1000
          )
        );
    }

    function isValidThyroid(data) {
      return data.keys().hasAll(['date', 'doseMcg', 'energyLevel'])
        && data.keys().size() >= 3
        && data.keys().size() <= 5
        && data.date is string
        && data.date.size() > 0
        && data.date.size() <= 50
        && (data.doseMcg is int || data.doseMcg is float)
        && data.doseMcg >= 0
        && data.doseMcg <= 1000
        && data.energyLevel is int
        && data.energyLevel >= 1
        && data.energyLevel <= 5
        && (
          !('weightKg' in data) || (
            data.weightKg is int || data.weightKg is float
          )
        )
        && (
          !('symptoms' in data) || (
            data.symptoms is list && data.symptoms.size() <= 20
          )
        );
    }

    function isValidAppointment(data) {
      return data.keys().hasAll(['patientName', 'phone', 'date', 'slot', 'type', 'specialty'])
        && data.keys().size() >= 6
        && data.keys().size() <= 12
        && data.patientName is string
        && data.patientName.size() > 0
        && data.patientName.size() <= 100
        && data.phone is string
        && data.phone.size() > 0
        && data.phone.size() <= 30
        && data.date is string
        && data.date.size() > 0
        && data.date.size() <= 50
        && data.slot is string
        && data.slot.size() > 0
        && data.slot.size() <= 50
        && data.type is string
        && (data.type == 'In-Person Clinic' || data.type == 'Video Teleconsultation' || data.type == 'Diagnostic Lab Test' || data.type == 'Home Sample Collection')
        && data.specialty is string
        && data.specialty.size() > 0
        && data.specialty.size() <= 100
        && (
          !('notes' in data) || (
            data.notes is string && data.notes.size() <= 1000
          )
        )
        && (
          !('qrCode' in data) || (
            data.qrCode is string && data.qrCode.size() <= 500
          )
        )
        && (
          !('id' in data) || (
            data.id is string && data.id.size() <= 64
          )
        )
        && (
          !('status' in data) || (
            data.status is string && data.status.size() <= 64
          )
        )
        && (
          !('labReport' in data) || (
            data.labReport is map
          )
        );
    }

    function isValidExternalReport(data) {
      return data.keys().hasAll(['patientName', 'phone', 'fileName', 'fileType', 'fileData', 'uploadedAt'])
        && data.keys().size() >= 6
        && data.keys().size() <= 8
        && data.patientName is string
        && data.patientName.size() > 0
        && data.patientName.size() <= 100
        && data.phone is string
        && data.phone.size() > 0
        && data.phone.size() <= 30
        && data.fileName is string
        && data.fileName.size() > 0
        && data.fileName.size() <= 200
        && data.fileType is string
        && (data.fileType == 'pdf' || data.fileType == 'image')
        && data.fileData is string
        && data.fileData.size() > 0
        && data.uploadedAt is string
        && (
          !('notes' in data) || (
            data.notes is string && data.notes.size() <= 1000
          )
        )
        && (
          !('id' in data) || (
            data.id is string && data.id.size() <= 64
          )
        );
    }

    function isValidVisit(data) {
      return data.keys().hasAll(['date', 'createdBy', 'prescriptions'])
        && data.date is string && data.date.size() > 0 && data.date.size() <= 50
        && (data.createdBy == 'doctor' || data.createdBy == 'staff')
        && data.prescriptions is list && data.prescriptions.size() <= 30
        && (!('vitals' in data) || data.vitals is map)
        && (!('complaint' in data) || (data.complaint is string && data.complaint.size() <= 2000))
        && (!('diagnosis' in data) || (data.diagnosis is string && data.diagnosis.size() <= 2000))
        && (!('advice' in data) || (data.advice is string && data.advice.size() <= 2000))
        && (!('followUpDate' in data) || (data.followUpDate is string && data.followUpDate.size() <= 20));
    }

    function isValidBill(data) {
      return data.keys().hasAll(['receiptNo', 'patientName', 'phone', 'date', 'items', 'total', 'paymentMode', 'createdBy'])
        && data.receiptNo is string && data.receiptNo.size() > 0 && data.receiptNo.size() <= 40
        && data.patientName is string && data.patientName.size() > 0 && data.patientName.size() <= 100
        && data.phone is string && data.phone.size() <= 30
        && data.date is string && data.date.size() > 0 && data.date.size() <= 50
        && data.items is list && data.items.size() > 0 && data.items.size() <= 20
        && (data.total is int || data.total is float) && data.total >= 0 && data.total <= 1000000
        && (data.paymentMode == 'Cash' || data.paymentMode == 'UPI' || data.paymentMode == 'Card')
        && (data.createdBy == 'doctor' || data.createdBy == 'staff')
        && (!('notes' in data) || (data.notes is string && data.notes.size() <= 1000));
    }

    function isValidWebBooking(data) {
      return data.keys().hasAll(['patientName', 'phone', 'date', 'slot', 'type', 'specialty', 'status', 'createdAt'])
        && data.keys().size() <= 9
        && data.patientName is string && data.patientName.size() > 0 && data.patientName.size() <= 100
        && data.phone is string && data.phone.size() >= 10 && data.phone.size() <= 30
        && data.date is string && data.date.size() > 0 && data.date.size() <= 20
        && data.slot is string && data.slot.size() > 0 && data.slot.size() <= 20
        && (data.type == 'In-Person Clinic' || data.type == 'Video Teleconsultation')
        && data.specialty is string && data.specialty.size() > 0 && data.specialty.size() <= 100
        && data.status == 'Requested'
        && data.createdAt is string && data.createdAt.size() <= 50
        && (!('notes' in data) || (data.notes is string && data.notes.size() <= 1000));
    }

    // Match Rules for Collections

    // Collection-group access so the clinic console can query appointments
    // across all patients (e.g. "today's appointments"). Read-only.
    match /{path=**}/appointments/{appointmentId} {
      allow get, list: if isActiveStaff();
    }

    // Collection-group access for the follow-up worklist (visits across all
    // patients). Read-only.
    match /{path=**}/visits/{visitId} {
      allow get, list: if isActiveStaff();
    }

    // Collection-group access for the billing tab (bills across all patients).
    match /{path=**}/bills/{billId} {
      allow get, list: if isActiveStaff();
    }

    // Booking requests from the public website (no patient account needed).
    // Anyone signed in (incl. anonymous) may create a valid request;
    // only staff can read, confirm, or remove them.
    match /webBookings/{requestId} {
      allow create: if isSignedIn() && isValidWebBooking(request.resource.data);
      allow get, list, update, delete: if isActiveStaff();
    }

    // Bills for walk-in / unregistered patients. Staff create; doctor deletes.
    match /clinicBills/{billId} {
      allow get, list: if isActiveStaff();
      allow create: if isActiveStaff() && isValidBill(request.resource.data);
      allow update, delete: if isDoctor();
    }

    // Bookings created by clinic staff for callers who are not registered
    // patients yet. Staff-only; validated like patient appointments.
    match /clinicBookings/{bookingId} {
      allow get, list: if isActiveStaff();
      allow create, update: if isActiveStaff() && isValidAppointment(request.resource.data);
      allow delete: if isActiveStaff();
    }

    // Staff password-rotation metadata: each staff account may manage only its
    // own record, and the timestamp can only ever be set to "now".
    match /staffMeta/{uid} {
      allow get: if isOwner(uid);
      allow create, update: if isOwner(uid)
        && isStaffEmail()
        && request.resource.data.keys().hasOnly(['passwordChangedAt'])
        && request.resource.data.passwordChangedAt == request.time;
      allow delete: if false;
    }

    match /users/{userId} {
      // Clinic staff (with a fresh password) may look up patient records.
      allow get, list: if isActiveStaff();
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isVerifiedUser() && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidId(userId) && isVerifiedUser() && isValidUser(request.resource.data) 
                    && request.resource.data.createdAt == resource.data.createdAt
                    && request.resource.data.email == resource.data.email;
      allow delete: if false;

      // Subcollections

      match /glucoseLogs/{logId} {
        allow get, list: if isActiveStaff();
        allow get, list: if isOwner(userId) && isValidId(userId);
        allow create: if isOwner(userId) && isValidId(userId) && isVerifiedUser() && isValidGlucose(request.resource.data);
        allow update: if isOwner(userId) && isValidId(userId) && isVerifiedUser() && isValidGlucose(request.resource.data)
                      && request.resource.data.timestamp == resource.data.timestamp;
        allow delete: if isOwner(userId) && isValidId(userId);
      }

      match /thyroidLogs/{logId} {
        allow get, list: if isActiveStaff();
        allow get, list: if isOwner(userId) && isValidId(userId);
        allow create: if isOwner(userId) && isValidId(userId) && isVerifiedUser() && isValidThyroid(request.resource.data);
        allow update: if isOwner(userId) && isValidId(userId) && isVerifiedUser() && isValidThyroid(request.resource.data)
                      && request.resource.data.date == resource.data.date;
        allow delete: if isOwner(userId) && isValidId(userId);
      }

      match /appointments/{appointmentId} {
        allow get, list: if isActiveStaff();
        allow create, update: if isActiveStaff() && isValidAppointment(request.resource.data);
        allow delete: if isActiveStaff();
        allow get, list: if isOwner(userId) && isValidId(userId);
        allow create: if isOwner(userId) && isValidId(userId) && isVerifiedUser() && isValidAppointment(request.resource.data);
        allow update: if isOwner(userId) && isValidId(userId) && isVerifiedUser() && isValidAppointment(request.resource.data);
        allow delete: if isOwner(userId) && isValidId(userId);
      }

      // Clinic visit records (vitals, notes, prescriptions) — written by
      // staff in the web console; patients may read their own.
      match /visits/{visitId} {
        allow get, list: if isActiveStaff();
        allow get, list: if isOwner(userId) && isValidId(userId);
        // Staff may record intake (vitals/complaint) only; prescriptions,
        // diagnosis, advice and follow-up require the doctor account.
        allow create, update: if isActiveStaff() && isValidVisit(request.resource.data)
          && (isDoctor() || (
            request.resource.data.prescriptions.size() == 0
            && request.resource.data.createdBy == 'staff'
            && !('diagnosis' in request.resource.data)
            && !('advice' in request.resource.data)
            && !('followUpDate' in request.resource.data)
          ));
        allow delete: if isDoctor();
      }

      // Bills for registered patients (patients may read their own).
      match /bills/{billId} {
        allow get, list: if isActiveStaff();
        allow get, list: if isOwner(userId) && isValidId(userId);
        allow create: if isActiveStaff() && isValidBill(request.resource.data);
        allow update, delete: if isDoctor();
      }

      match /externalReports/{reportId} {
        allow get, list: if isActiveStaff();
        allow get, list: if isOwner(userId) && isValidId(userId);
        allow create: if isOwner(userId) && isValidId(userId) && isVerifiedUser() && isValidExternalReport(request.resource.data);
        allow update: if isOwner(userId) && isValidId(userId) && isVerifiedUser() && isValidExternalReport(request.resource.data);
        allow delete: if isOwner(userId) && isValidId(userId);
      }
    }
  }
}
